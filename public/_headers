# Production HTTP Headers for FlowMatch

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  X-XSS-Protection: 1; mode=block
  Permissions-Policy: geolocation=(), camera=(), microphone=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://*.supabase.in; img-src 'self' data: https://*.supabase.co; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; frame-ancestors 'none';

# Cache Fingerprinted Assets Immutable
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Cache Metadata Chunk Files
/data/indexed-workflows/*
  Cache-Control: public, max-age=3600, must-revalidate
