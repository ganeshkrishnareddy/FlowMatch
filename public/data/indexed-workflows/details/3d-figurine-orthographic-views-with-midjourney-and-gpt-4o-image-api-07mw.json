                "leftValue": "={{ $json.finish_reason }}",
                "rightValue": "not_found"
              },
              {
                "id": "ed245d42-677f-4465-a3f1-d23c6e609f5e",
                "operator": {
                  "name": "filter.operator.equals",
                  "type": "string",
                  "operation": "equals"
                },
                "leftValue": "",
