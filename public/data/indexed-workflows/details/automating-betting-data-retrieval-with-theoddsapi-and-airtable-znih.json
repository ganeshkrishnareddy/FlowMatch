        "position": [
          -420,
          -200
        ],
        "parameters": {
          "rule": {
            "interval": [
              {
                "triggerAtHour": 7
              }
            ]
          }
        },
        "typeVersion": 1.2,
        "notes": "This scheduleTrigger node performs automated tasks as part of the workflow."
