        "parameters": {
          "rules": {
            "rules": [
              {
                "value2": "Louis Litt <louis_litt_1970@yahoo.com>"
              }
            ]
          },
          "value1": "={{$node[\"Read Harvey's Email\"].json[\"from\"]}}",
          "dataType": "string",
          "fallbackOutput": 3
