      },
      {
        "id": "d77cad4d-8899-4345-bf29-ba21cef946cd",
        "name": "Initiate a Webhook Request",
        "type": "n8n-nodes-base.noOp",
        "position": [
          1920,
          -200
        ],
        "parameters": {
          "url": "{{ $env.WEBHOOK_URL }}",
          "method": "POST",
          "sendBody": true,
          "parametersBody": {
            "values": [
              {
                "name": "search_summary",
                "value": "={{ $json.response.text }}",
                "valueProvider": "fieldValue"
              },
              {
                "name": "search_result"
              }
            ]
          },
          "toolDescription": "Extract the response and format a structured JSON response"
        },
        "typeVersion": 1.1,
        "notes": "This toolHttpRequest node performs automated tasks as part of the workflow."
      },
      {
        "id": "b94deec3-3394-4fb3-b700-9ed3ced877ca",
        "name": "Initiate a Webhook Notification for Summarization",
        "type": "n8n-nodes-base.httpRequest",
        "position": [
          1780,
          -700
        ],
        "parameters": {
          "url": "{{ $env.WEBHOOK_URL }}",
          "options": {},
          "sendBody": true,
          "bodyParameters": {
            "parameters": [
              {
                "name": "summary",
                "value": "={{ $json.response.text }}"
              }
            ]
          }
        },
        "typeVersion": 4.2,
        "notes": "This httpRequest node performs automated tasks as part of the workflow."
      }
    ],
