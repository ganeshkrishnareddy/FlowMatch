        "parameters": {
          "url": "{{ $env.WEBHOOK_URL }}",
          "options": {},
          "sendBody": true,
          "bodyParameters": {
            "parameters": [
              {
                "name": "content",
                "value": "={{ $json.response.text }}"
              }
