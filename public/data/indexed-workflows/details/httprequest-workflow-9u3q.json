        ],
        "parameters": {
          "width": 181,
          "height": 364,
          "content": "### 1. Define your Bluesky user and app password first\n\nThe App password should have access to private messages"
        },
        "typeVersion": 1,
        "notes": "This stickyNote node performs automated tasks as part of the workflow."
