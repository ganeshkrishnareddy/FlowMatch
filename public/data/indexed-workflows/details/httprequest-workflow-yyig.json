    "name": "Httprequest Workflow",
    "nodes": [
      {
        "name": "Combine all activity for a company",
        "parameters": {
          "joinMode": "keepEverything",
          "mergeByFields": {
            "values": [
              {
                "field1": "name",
                "field2": "name"
              }
            ]
          },
          "mode": "combine",
          "options": {
            "clashHandling": {
              "values": {
