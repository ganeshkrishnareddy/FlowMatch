          360
        ],
        "parameters": {
          "options": {},
          "respondWith": "json",
          "responseBody": "{\n \"error\": \"Invalid inputs.\"\n}"
        },
        "typeVersion": 1.1,
        "notes": "This respondToWebhook node performs automated tasks as part of the workflow."
      }
    ],
