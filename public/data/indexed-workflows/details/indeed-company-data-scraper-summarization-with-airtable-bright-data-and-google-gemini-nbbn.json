          "url": "{{ $env.API_BASE_URL }}",
          "method": "POST",
          "options": {},
          "sendBody": true,
          "sendHeaders": true,
          "authentication": "{{ $credentials.genericCredentialType }}",
          "bodyParameters": {
            "parameters": [
              {
                "name": "zone",
                "value": "={{ $('Set Bright Data Zone').item.json.zone }}"
              },
              {
                "name": "url",
                "value": "={{ $env.WEBHOOK_URL }}{{ encodeURI($('Airtable').item.json.Link) }}?product=unlocker&method=api"
              },
              {
                "name": "format",
                "value": "raw"
              },
              {
                "name": "data_format",
                "value": "markdown"
              }
