        },
        "type": "n8n-nodes-base.noOp",
        "typeVersion": 1
      },
      {
        "name": "If Link field is not empty",
        "parameters": {
          "conditions": {
            "combinator": "and",
            "conditions": [
              {
                "id": "42eae1de-1d71-4418-862d-9cb9f8fb44e6",
                "leftValue": "={{ $json.Link }}",
                "operator": {
                  "operation": "notEmpty",
                  "singleValue": true,
                  "type": "string"
                },
                "rightValue": ""
              }
            ],
            "options": {
              "caseSensitive": true,
              "leftValue": "",
              "typeValidation": "strict",
              "version": 2
            }
          },
          "options": {}
        },
        "type": "n8n-nodes-base.if",
        "typeVersion": 2.2
      },
      {
        "name": "Indeed Expert AI Agent",
        "parameters": {
          "options": {},
          "promptType": "define",
          "text": "=You are an Indeed Expert. You need to format the search result  and push it to the Webhook via HTTP Request. Here is the search result - {{ $('Markdown to Textual Data Extractor').item.json.text }}"
        },
        "type": "n8n-nodes-base.noOp",
        "typeVersion": 1.8
      },
      {
        "name": "Indeed Summarizer",
        "parameters": {
          "options": {}
        },
        "type": "n8n-nodes-base.noOp",
        "typeVersion": 2
      },
      {
        "name": "Initiate a Webhook Notification for Markdown to HTML Response",
        "parameters": {
          "bodyParameters": {
            "parameters": [
              {
                "name": "html_response",
                "value": "={{ $json.data }}"
              }
            ]
          },
          "options": {},
          "sendBody": true,
          "url": "{{ $env.WEBHOOK_URL }}"
        },
        "type": "n8n-nodes-base.httpRequest",
