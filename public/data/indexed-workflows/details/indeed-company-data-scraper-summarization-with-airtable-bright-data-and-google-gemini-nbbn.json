        "type": "n8n-nodes-base.splitInBatches",
        "typeVersion": 3
      },
      {
        "name": "Markdown to Textual Data Extractor",
        "parameters": {
          "messages": {
            "messageValues": [
              {
                "message": "You are a markdown expert"
              }
            ]
          },
          "promptType": "define",
          "text": "=You need to analyze the below markdown and convert to textual data.\n\n{{ $json.data }}"
