      {
        "id": "158e7b18-f58d-453f-80f8-97e65f0b1fde",
        "name": "Parse JSON",
        "type": "n8n-nodes-base.set",
        "position": [
          1780,
          300
        ],
        "parameters": {
          "values": {
            "string": [
              {
                "name": "data",
                "value": "={{ JSON.parse($json.script) }}"
