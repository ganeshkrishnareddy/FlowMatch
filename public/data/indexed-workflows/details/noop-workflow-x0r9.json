          "genericAuthType": "httpHeaderAuth",
          "queryParameters": {
            "parameters": [
              {
                "name": "email",
                "value": "={{ $json.email }}"
              },
              {
                "name": "required",
                "value": "work_email,personal_email,email"
              }
            ]
          }
        },
        "credentials": {
          "httpHeaderAuth": {
            "id": "kyMNOdXZX3ugPihF",
            "name": "ExactBuyer Api key"
          }
        },
        "typeVersion": 4.1,
        "notes": "This httpRequest node performs automated tasks as part of the workflow."
      }
