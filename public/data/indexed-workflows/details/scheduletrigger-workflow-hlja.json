        "typeVersion": 1,
        "notes": "This stickyNote node performs automated tasks as part of the workflow."
      },
      {
        "id": "2bac2f08-2969-4f47-9fce-0e7de416cd09",
        "name": "Sticky Note1",
        "type": "n8n-nodes-base.stickyNote",
        "position": [
          280,
          -60
        ],
        "parameters": {
