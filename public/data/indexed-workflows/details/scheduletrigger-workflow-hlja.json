        "id": "2f9757fc-77f5-4bda-ae2e-7088ea5c114d",
        "name": "Config",
        "type": "n8n-nodes-base.set",
        "position": [
          380,
          120
        ],
        "parameters": {
          "options": {},
          "assignments": {
            "assignments": [
              {
                "id": "cd2665dd-b505-41e4-936d-cfa2de7bd09b",
