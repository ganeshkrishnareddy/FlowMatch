        "parameters": {
          "color": 7,
          "width": 320,
          "height": 500,
          "content": "# Discard found Google Apps documents\nDocs, Sheets, Forms, Slides, Drawins etc. are discarded because they are not actual binary files and their content can't be directly checked."
