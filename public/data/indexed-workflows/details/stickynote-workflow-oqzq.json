          1460,
          140
        ],
        "parameters": {
          "domain": "={{ $json[$('Setup').first().json.domainCustomFieldId2]}}",
          "additionalFields": {}
        },
        "credentials": {
          "clearbitApi": {
            "id": "cKDImrinp9tg0ZHW",
            "name": "Clearbit account"
          }
        },
        "typeVersion": 1,
