            "id": "{{ $credentials.telegramApi.id }}",
            "name": "Telegram bot"
          }
        },
        "typeVersion": 1,
        "notes": "This telegram node performs automated tasks as part of the workflow."
      },
      {
        "id": "30321276-ebe1-41ac-b420-9dab8daa405b",
