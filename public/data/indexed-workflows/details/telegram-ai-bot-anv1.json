        "name": "Telegram Trigger",
        "type": "n8n-nodes-base.telegramTrigger",
        "position": [
          20,
          340
        ],
        "webhookId": "51942fbb-ca0e-4ec4-9423-5fcc7d3c4281",
        "parameters": {
          "updates": [
            "*"
