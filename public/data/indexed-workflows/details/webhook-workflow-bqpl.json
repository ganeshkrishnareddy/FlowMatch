          "documentId": {
            "__rl": true,
            "mode": "url",
            "value": "={{ $json['Google Sheets URL'] }}"
          }
        },
        "typeVersion": 4.3,
        "notes": "This googleSheets node performs automated tasks as part of the workflow."
      },
      {
        "id": "51f80b29-4b8c-4e2a-9da9-a7409763af0c",
