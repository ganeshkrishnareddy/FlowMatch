        "type": "n8n-nodes-base.googleSheets",
        "position": [
          1780,
          360
        ],
        "parameters": {
          "columns": {
            "value": {
              "Name": "={{ $('Webhook').item.json.body.text }}",
              "Creator": "={{ $('Webhook').item.json.body.user_name }}"
            },
            "schema": [
              {
                "id": "Name",
                "type": "string",
                "display": true,
                "removed": false,
                "required": false,
                "displayName": "Name",
                "defaultMatch": false,
                "canBeUsedToMatch": true
