              {
                "id": "Creator",
                "type": "string",
                "display": true,
                "required": false,
                "displayName": "Creator",
                "defaultMatch": false,
                "canBeUsedToMatch": true
              }
            ],
            "mappingMode": "defineBelow",
            "matchingColumns": [
              "Name"
            ]
          },
          "options": {
            "cellFormat": "USER_ENTERED"
          },
          "operation": "appendOrUpdate",
          "sheetName": {
            "__rl": true,
            "mode": "list",
            "value": "gid=0",
            "cachedResultUrl": "{{ $env.WEBHOOK_URL }}",
            "cachedResultName": "Sheet1"
