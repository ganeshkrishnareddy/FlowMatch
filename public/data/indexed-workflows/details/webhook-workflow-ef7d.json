                  "combinator": "and",
                  "conditions": [
                    {
                      "id": "68917137-6042-4e47-9432-d006dca17872",
                      "leftValue": "={{ $json[\"Product Purchased\"] }}",
                      "operator": {
                        "operation": "equals",
                        "type": "string"
                      },
                      "rightValue": "=AI-Powered Social Media Content Generator & Publisher"
                    }
                  ],
                  "options": {
                    "caseSensitive": true,
                    "leftValue": "",
                    "typeValidation": "strict",
                    "version": 2
                  }
                },
                "outputKey": "YOUR_CREDENTIAL_HERE",
