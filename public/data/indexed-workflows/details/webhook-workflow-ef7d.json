                  ],
                  "options": {
                    "caseSensitive": true,
                    "leftValue": "",
                    "typeValidation": "strict",
                    "version": 2
                  }
                },
                "outputKey": "YOUR_CREDENTIAL_HERE",
                "renameOutput": true
              }
            ]
          }
        },
        "type": "n8n-nodes-base.switch",
        "typeVersion": 3.2
      },
