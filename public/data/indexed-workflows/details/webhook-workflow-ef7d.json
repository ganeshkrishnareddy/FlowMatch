                  "conditions": [
                    {
                      "id": "68917137-6042-4e47-9432-d006dca17872",
                      "leftValue": "={{ $json.body.event_type }}",
                      "operator": {
                        "operation": "equals",
                        "type": "string"
                      },
                      "rightValue": "=PAYMENT.CAPTURE.COMPLETED"
