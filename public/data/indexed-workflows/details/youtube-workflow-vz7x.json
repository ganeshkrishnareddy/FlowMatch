    "name": "Youtube Workflow",
    "nodes": [
      {
        "name": "Check for errors",
        "parameters": {
          "conditions": {
            "combinator": "and",
            "conditions": [
              {
                "id": "5972ff90-aa5a-470c-aa96-87138eb60565",
                "leftValue": "={{ $json.error }}",
